# Bot token from @BotFather
BOT_TOKEN=

# Admin Telegram user IDs, comma-separated (e.g. 123456789,987654321)
ADMIN_IDS=

# ---------- Telegram Stars ----------
STARS_ENABLED=false
STARS_PROVIDER_TOKEN=

# ---------- CryptoBot ----------
CRYPTO_ENABLED=false
CRYPTO_API_TOKEN=

# ---------- Stripe ----------
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://t.me/your_bot
STRIPE_CANCEL_URL=https://t.me/your_bot

# ---------- Alipay / WeChat Backend Routing ----------
# Choose which backend processes each channel: "epay" or "hupijiao"
# Leave empty to disable that channel
ALIPAY_BACKEND=hupijiao
WECHAT_BACKEND=epay

# ---------- Epay Backend (易支付) ----------
EPAY_ENABLED=false
EPAY_API_URL=
EPAY_PID=
EPAY_KEY=
EPAY_NOTIFY_URL=

# ---------- HuPiJiao V3 Backend (虎皮椒) ----------
# Register at https://www.xunhupay.com
HUPIJIAO_ENABLED=false
HUPIJIAO_API_URL=https://api.xunhupay.com
HUPIJIAO_APPID=
HUPIJIAO_APPSECRET=
HUPIJIAO_NOTIFY_URL=

# ---------- Webhook Server ----------
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000

# ---------- Admin Web Panel ----------
# Default: admin / 123456. First login forces password change.
# Override here to set different initial credentials.
#ADMIN_PANEL_USERNAME=admin
#ADMIN_PANEL_PASSWORD=123456
# Optional: restrict /admin to these IPs (comma-separated). Empty = allow all.
#ADMIN_PANEL_ALLOWED_IPS=1.2.3.4,10.0.0.1

# ---------- Database ----------
DATABASE_URL=sqlite+aiosqlite:///data/bot.db
